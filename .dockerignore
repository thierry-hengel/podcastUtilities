# ==============================================================================
# Docker Ignore File - Podcast Utilities Project
# ==============================================================================

# --- Git History (Optimization) ---
# Exclude the .git folder to reduce build context size
.git/

# --- Python Environment & Bytecode ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.env

# --- Project-specific Source Code ---
# Exclude original .py files; Docker will only use the protected ones from 'dist/'
*.py

# --- Local Scripts & Maintenance ---
# Do not include the dev build script inside the production image
build_blackbox.sh

# --- Local Data & Persistence ---
# Exclude local media, logs, and profiles (handled via Docker Volumes)
downloads/
logs/
profiles/
configuration/police & logo/

# --- Configuration & Setup ---
# Exclude local setup scripts and configuration folders
configuration/
setup/
!setup/Firefox
TODO.txt
github_deployment_commands.md
setup.cfg

# --- IDE Settings ---
.vscode/